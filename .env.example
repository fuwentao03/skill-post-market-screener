# ===========================================================================
# Environment Variables for Post-Market Screener
# ===========================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.
# ===========================================================================

# ── Pandadata API credentials (required for live data) ─────────────────────
# Username must use "86" prefix for Chinese phone numbers (e.g. 8618046753943).
# These can also be set in config.json: pandadata.username / pandadata.password
DEFAULT_USERNAME=
DEFAULT_PASSWORD=

# ── LLM API (Claude or DeepSeek) ───────────────────────────────────────────
# API key — resolved as: ANTHROPIC_API_KEY > ANTHROPIC_AUTH_TOKEN > config.json
ANTHROPIC_API_KEY=

# Alternative: DeepSeek auth token (set this OR ANTHROPIC_API_KEY)
ANTHROPIC_AUTH_TOKEN=

# Model name (default: claude-sonnet-4-6)
# DeepSeek: deepseek-v4-pro (or deepseek-chat)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Base URL — uncomment for DeepSeek or other Anthropic-compatible endpoints
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
